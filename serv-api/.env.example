# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/serv_db?schema=public"

# Auth
ADMIN_PASSWORD="change_me"
JWT_SECRET="change_me_to_a_long_random_string"

# App
PORT=3000
# Comma-separated list of allowed frontend origins
FRONTEND_URL="http://localhost:5173,https://yourdomain.com"

# reCAPTCHA (leave empty to skip validation in dev)
RECAPTCHA_SECRET=""

# Bitrix CRM webhook
BITRIX_WEBHOOK_URL="https://bitrix.yourdomain.com/rest/USER_ID/TOKEN/crm.lead.add.json"

# Rate limiting (optional overrides)
# BLOCKED_IPS=""

# Backup retention (days) — used by scripts/backup.sh
# KEEP_DAYS=7
